# Docker-compose might get confused when there are multiple "service" directories, so let's help it by providing a specific project name.
COMPOSE_PROJECT_NAME=signmemaybe_service
ASPNETCORE_ENVIRONMENT=Production
SIGNMEMAYBE_DB_PATH=/data/signmemaybe.sqlite3
SIGNMEMAYBE_PDF_ROOT=/data/pdfs
SIGNMEMAYBE_EXPORT_ROOT=/data/exports
SIGNMEMAYBE_MAX_UPLOAD_BYTES=10485760